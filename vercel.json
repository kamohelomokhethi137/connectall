{
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/((?!.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|webmanifest|xml|txt|webp|avif|woff|woff2|ttf|eot)$).*)",
      "dest": "/index.html"
    }
  ]
}